---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const { title = "Alisia Martinez", description = "" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>

  <body>
    <div class="pointer-events-none fixed inset-0 opacity-[0.05]">
  <div class="absolute inset-0 bg-[radial-gradient(#000_1px,transparent_1px)] [background-size:18px_18px]"></div>
</div>
    <Nav />
    <main class="container section">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const elastic = (t) => {
          if (t === 0 || t === 1) return t;
          return Math.pow(2, -10 * t) * Math.sin((t * 10 - 0.75) * ((2 * Math.PI) / 3)) + 1;
        };

        const initSpringHover = (selector, settings) => {
          const elements = Array.from(document.querySelectorAll(selector));
          if (!elements.length) return;

          const stateMap = new WeakMap();
          const rafMap = new WeakMap();

          const stopAnim = (el) => {
            const raf = rafMap.get(el);
            if (raf) cancelAnimationFrame(raf);
          };

          const animate = (el, opts) => {
            stopAnim(el);
            const base = stateMap.get(el) || { y: 0, z: 0, scale: 1, rot: 0 };
            const target = {
              y: opts.direction === "out" ? 0 : opts.y ?? 0,
              z: opts.direction === "out" ? 0 : opts.z ?? 0,
              scale: opts.direction === "out" ? 1 : opts.scale ?? 1,
              rot: opts.direction === "out" ? 0 : opts.rot ?? 0,
            };

            const start = performance.now();
            const durTranslate = settings.duration * 0.9;
            const durScale = settings.duration * 1.15;
            const durRotate = settings.duration * 1.3;

            const tick = (now) => {
              const tTranslate = Math.min((now - start) / durTranslate, 1);
              const tScale = Math.min((now - start) / durScale, 1);
              const tRotate = Math.min((now - start) / durRotate, 1);

              const y = base.y + (target.y - base.y) * elastic(tTranslate);
              const z = base.z + (target.z - base.z) * elastic(tTranslate);
              const scale = base.scale + (target.scale - base.scale) * elastic(tScale);
              const rot = base.rot + (target.rot - base.rot) * elastic(tRotate);

              el.style.transform = `translate3d(0, ${y}px, ${z}px) rotate(${rot}deg) scale(${scale})`;
              stateMap.set(el, { y, z, scale, rot });

              if (tTranslate < 1 || tScale < 1 || tRotate < 1) {
                rafMap.set(el, requestAnimationFrame(tick));
                return;
              }

              rafMap.delete(el);
            };

            rafMap.set(el, requestAnimationFrame(tick));
          };

          elements.forEach((el) => {
            el.style.transformOrigin = "50% 50%";
            el.style.willChange = "transform";

            el.addEventListener("pointerenter", () => {
              const rot = settings.rotMax ? Math.random() * settings.rotMax * 2 - settings.rotMax : 0;
              animate(el, {
                y: settings.y,
                z: settings.z,
                scale: settings.scale,
                rot,
                direction: "in",
              });
            });

            const onLeave = () => animate(el, { direction: "out" });
            el.addEventListener("pointerleave", onLeave);
            el.addEventListener("pointercancel", onLeave);
            el.addEventListener("blur", onLeave);
          });
        };

        initSpringHover(".js-bouncy-pill", {
          y: -4,
          z: 10,
          scale: 1.06,
          rotMax: 2,
          duration: 520,
        });

        initSpringHover(".js-bouncy-nav", {
          y: 0,
          z: 0,
          scale: 1.07,
          rotMax: 0,
          duration: 460,
        });

        initSpringHover(".js-bouncy-brand", {
          y: 0,
          z: 0,
          scale: 1.12,
          rotMax: 0,
          duration: 500,
        });
      })();
    </script>
  </body>
</html>
