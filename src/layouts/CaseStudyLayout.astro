---
import BaseLayout from "./BaseLayout.astro";
import Pill from "../components/Pill.astro";
import Media from "../components/Media.astro";
import CasePhoneMedia from "../components/CasePhoneMedia.astro";
import CaseMediaPair from "../components/CaseMediaPair.astro";
import CaseMotionMedia from "../components/CaseMotionMedia.astro";
import { getTagStyles } from "../utils/tagStyles";
import { withBasePath } from "../utils/path";

const { entry } = Astro.props;
const data = entry.data;

// Precompute view-model-y stuff once
const roles = data.roles ?? [];
const rolesText = roles.length > 0 ? roles.join(" • ") : null;
const tags = data.tags ?? [];
const tagStyles = getTagStyles(tags);
const coloredTags = tags.map((label) => {
  return { label, colors: tagStyles[label] };
});
const hasTimeline = Boolean(data.timeline);
const toolsText = (data.tools?.length ?? 0) > 0 ? data.tools.join(" • ") : null;
const base = import.meta.env.BASE_URL;
const resolvedLogoSrc = data.logoSrc
  ? withBasePath(data.logoSrc.startsWith("/") ? data.logoSrc : `/${data.logoSrc}`, base)
  : undefined;

const hero = data.hero; // { type?, src, alt? } (whatever your schema is)
const atAGlance = data.atAGlance; // { problem, built, impact }
const atAGlanceCards = atAGlance
  ? [
      {
        key: "problem",
        label: "Problem",
        copy: atAGlance.problem,
        emoji: "⚠️",
      },
      {
        key: "built",
        label: "What I built",
        copy: atAGlance.built,
        emoji: "🧩",
      },
      {
        key: "impact",
        label: "Impact",
        copy: atAGlance.impact,
        emoji: "✅",
      },
    ]
  : [];
const processSections = [
  { id: "overview", label: "Overview" },
  { id: "challenge", label: "Challenge" },
  { id: "approach", label: "Approach" },
  { id: "process", label: "Process" },
  { id: "outcome", label: "Outcome" },
];
---

<BaseLayout title={`Alisia Martinez - ${data.title}`} description={data.description}>
  <article class="case">
    <header class="case__header">
      <div class="case__header-top">
        <h1 class="case__title text-4xl md:text-5xl font-semibold tracking-tight">{data.title}</h1>
        {resolvedLogoSrc && (
          <div class="case__logo-wrap">
            <img src={resolvedLogoSrc} alt={data.logoAlt ?? `${data.title} logo`} class="case__logo" loading="lazy" />
          </div>
        )}
      </div>

      {data.description && <p class="case__desc">{data.description}</p>}

      {coloredTags.length > 0 && (
        <div class="case__pills">
          {coloredTags.map((tag) => (
            <Pill
              text={tag.label}
              className="js-bouncy-pill"
              style={`background:${tag.colors.bg};border-color:${tag.colors.border};color:${tag.colors.text};`}
            />
          ))}
        </div>
      )}

      <dl class="case__meta">
        {rolesText && (
          <>
            <dt>Roles</dt>
            <dd class="case__meta-roles">{rolesText}</dd>
          </>
        )}

        {hasTimeline && (
          <>
            <dt>Timeline</dt>
            <dd>{data.timeline}</dd>
          </>
        )}

        {toolsText && (
          <>
            <dt>Tools</dt>
            <dd>{toolsText}</dd>
          </>
        )}
      </dl>
    </header>

    {hero && (
      <section class="case__hero">
        {hero.type === "phone" ? (
          <CasePhoneMedia src={hero.src} alt={hero.alt ?? data.title} caption={hero.caption} />
        ) : hero.type === "pair" ? (
          <CaseMediaPair
            leftSrc={hero.leftSrc}
            leftAlt={hero.leftAlt}
            rightSrc={hero.rightSrc}
            rightAlt={hero.rightAlt}
            caption={hero.caption}
          />
        ) : hero.type === "motion" ? (
          <CaseMotionMedia
            src={hero.src}
            alt={hero.alt ?? data.title}
            caption={hero.caption}
            loop={hero.loop}
            autoplay={hero.autoplay}
            muted={hero.muted}
            controls={hero.controls}
          />
        ) : (
          <Media type={hero.type ?? "image"} src={hero.src} alt={hero.alt ?? data.title} />
        )}
      </section>
    )}

    {atAGlance && (
      <section class="case__ataglance case__systems" aria-label="At a glance system summary">
        <div class="case__systems-grid">
          {atAGlanceCards.map((card) => (
            <article class={`systems-card systems-card--${card.key}`} tabindex="0">
              <span class="systems-card__rail" aria-hidden="true"></span>
              <header class="systems-card__head">
                <h2 class="systems-card__title">
                  <span aria-hidden="true">{card.emoji}</span>
                  <span>{card.label}</span>
                </h2>
              </header>
              <p class="systems-card__copy">{card.copy}</p>
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="case__body" aria-label="Case study process">
      <details class="case__toc-mobile">
        <summary>On this page</summary>
        <nav aria-label="On this page">
          <ol>
            {processSections.map((section) => (
              <li>
                <a href={`#${section.id}`}>{section.label}</a>
              </li>
            ))}
          </ol>
        </nav>
      </details>

      <div class="case__body-layout">
        <aside class="case__toc-desktop" aria-label="On this page">
          <p>On this page</p>
          <ol>
            {processSections.map((section) => (
              <li>
                <a href={`#${section.id}`}>{section.label}</a>
              </li>
            ))}
          </ol>
        </aside>

        <div class="case__content">
          <slot />
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* keep/replace with your existing styling system */
  .case { max-width: 980px; margin: 0 auto; padding: 48px 20px; }
  .case__header { display: grid; gap: 16px; }
  .case__header-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; }
  .case__title { margin: 0; }
  .case__logo-wrap {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    border: 1px solid rgba(17,17,17,0.12);
    background: rgba(255,255,255,0.65);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .case__logo { width: 38px; height: 38px; object-fit: contain; }
  .case__desc { margin: 0; opacity: 0.9; }
  .case__pills { display: flex; flex-wrap: wrap; gap: 8px; }
  .case__meta { display: grid; grid-template-columns: 120px 1fr; gap: 8px 16px; margin: 8px 0 0; }
  .case__meta dt { opacity: 0.7; }
  .case__meta dd { margin: 0; }
  .case__meta-roles { font-weight: 600; }
  .case__hero { margin-top: 24px; }
  .case__ataglance { margin-top: 28px; }
  .case__systems-grid { display: grid; gap: 16px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .systems-card {
    --card-accent: #1D4ED8;
    --card-tint: #EFF6FF;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 14px 14px 14px 18px;
    background: var(--card-tint);
    box-shadow: 0 1px 2px rgba(17,17,17,0.02), 0 6px 18px rgba(17,17,17,0.03);
    transition: border-color 180ms ease, box-shadow 200ms ease, transform 200ms ease;
    outline: none;
    position: relative;
    overflow: hidden;
  }
  .systems-card--problem { --card-accent: #B45309; --card-tint: #FFFBEB; }
  .systems-card--built { --card-accent: #1D4ED8; --card-tint: #EFF6FF; }
  .systems-card--impact { --card-accent: #15803D; --card-tint: #ECFDF5; }
  .systems-card__rail {
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: var(--card-accent);
    opacity: 0.62;
    transition: opacity 180ms ease;
  }
  .systems-card__head { margin-bottom: 10px; }
  .systems-card__title {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: rgba(17,17,17,0.75);
  }
  .systems-card__copy {
    margin: 0;
    font-size: 0.99rem;
    line-height: 1.6;
    color: rgba(17,17,17,0.9);
  }
  .systems-card:hover,
  .systems-card:focus-visible {
    border-color: color-mix(in oklab, var(--ink) 24%, var(--card-accent) 16%);
    box-shadow: 0 2px 4px rgba(17,17,17,0.03), 0 12px 28px rgba(17,17,17,0.09);
    transform: translateY(-2px);
  }
  .systems-card:hover .systems-card__rail,
  .systems-card:focus-visible .systems-card__rail {
    opacity: 1;
  }
  .systems-card:focus-visible {
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--card-accent) 30%, white), 0 10px 24px rgba(17,17,17,0.08);
  }
  .case__body { margin-top: 44px; }
  .case__body-layout { display: grid; grid-template-columns: 220px minmax(0, 1fr); gap: 36px; align-items: start; }

  .case__toc-mobile { display: none; margin-bottom: 24px; border: 1px solid rgba(17,17,17,0.12); border-radius: 10px; padding: 12px 14px; background: rgba(255,255,255,0.7); }
  .case__toc-mobile summary { cursor: pointer; font-size: 0.92rem; font-weight: 600; list-style: none; }
  .case__toc-mobile summary::-webkit-details-marker { display: none; }
  .case__toc-mobile ol { margin: 10px 0 0; padding-left: 1rem; display: grid; gap: 6px; }

  .case__toc-desktop { position: sticky; top: 96px; border-left: 1px solid rgba(17,17,17,0.12); padding-left: 14px; }
  .case__toc-desktop p { margin: 0 0 10px; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(17,17,17,0.6); }
  .case__toc-desktop ol { margin: 0; padding: 0; list-style: none; display: grid; gap: 8px; }
  .case__toc-desktop a,
  .case__toc-mobile a { color: inherit; text-decoration: none; font-size: 0.92rem; }
  .case__toc-desktop a:hover,
  .case__toc-mobile a:hover { text-decoration: underline; text-underline-offset: 3px; }

  .case__content { min-width: 0; }
  .case__content :global(h2) { margin: 64px 0 14px; font-size: 1.75rem; line-height: 1.2; font-weight: 600; letter-spacing: -0.015em; scroll-margin-top: 112px; }
  .case__content :global(h2:first-child) { margin-top: 0; }
  .case__content :global(p),
  .case__content :global(li) { font-size: 1.05rem; line-height: 1.85; max-width: 72ch; }
  .case__content :global(p) { margin: 0 0 18px; color: rgba(17,17,17,0.92); }
  .case__content :global(ul),
  .case__content :global(ol) { margin: 0 0 24px 1.25rem; padding: 0; display: grid; gap: 8px; }
  .case__content :global(blockquote) { margin: 0 0 24px; padding-left: 14px; border-left: 2px solid rgba(17,17,17,0.2); color: rgba(17,17,17,0.72); }
  .case__content :global(hr) { margin: 36px 0; border: 0; border-top: 1px dashed rgba(17,17,17,0.2); }
  .case__content :global(img),
  .case__content :global(video) { border-radius: 12px; margin: 24px 0; }

  @media (max-width: 960px) {
    .case__body-layout { grid-template-columns: minmax(0, 1fr); }
    .case__toc-desktop { display: none; }
    .case__toc-mobile { display: block; }
  }

  @media (max-width: 800px) {
    .case__header-top { align-items: center; }
    .case__logo-wrap { width: 46px; height: 46px; border-radius: 10px; }
    .case__logo { width: 32px; height: 32px; }
    .case__systems-grid { grid-template-columns: 1fr; }
    .case__meta { grid-template-columns: 1fr; }
    .case__content :global(h2) { font-size: 1.45rem; margin-top: 52px; scroll-margin-top: 96px; }
    .case__content :global(p),
    .case__content :global(li) { font-size: 1rem; line-height: 1.75; }
  }
  @media (prefers-reduced-motion: reduce) {
    .systems-card,
    .systems-card__rail {
      transition: none;
    }
    .systems-card:hover,
    .systems-card:focus-visible {
      transform: none;
    }
  }
</style>

<script is:inline>
  const quantizeChannel = (value) => Math.round(value / 8) * 8;
  const hasMeaningfulTransparency = (pixels, w, h) => {
    const totalPixels = w * h;
    const stride = totalPixels > 40000 ? 16 : 4;
    let sampled = 0;
    let transparent = 0;

    for (let i = 3; i < pixels.length; i += stride * 4) {
      sampled += 1;
      if (pixels[i] < 245) transparent += 1;
    }

    return sampled > 0 && transparent / sampled > 0.01;
  };

  const pickEdgeColor = (img) => {
    const w = img.naturalWidth;
    const h = img.naturalHeight;
    if (!w || !h) return null;

    const canvas = document.createElement("canvas");
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    if (!ctx) return null;

    ctx.drawImage(img, 0, 0, w, h);
    let imageData;
    try {
      imageData = ctx.getImageData(0, 0, w, h).data;
    } catch {
      return null;
    }
    if (hasMeaningfulTransparency(imageData, w, h)) return null;

    const bins = new Map();
    const addPixel = (x, y) => {
      const i = (y * w + x) * 4;
      const a = imageData[i + 3];
      if (a < 24) return;
      const r = quantizeChannel(imageData[i]);
      const g = quantizeChannel(imageData[i + 1]);
      const b = quantizeChannel(imageData[i + 2]);
      const key = `${r},${g},${b}`;
      bins.set(key, (bins.get(key) ?? 0) + a);
    };

    for (let x = 0; x < w; x++) {
      addPixel(x, 0);
      addPixel(x, h - 1);
    }
    for (let y = 1; y < h - 1; y++) {
      addPixel(0, y);
      addPixel(w - 1, y);
    }

    if (bins.size === 0) return null;

    let bestKey = null;
    let bestScore = -1;
    for (const [key, score] of bins) {
      if (score > bestScore) {
        bestScore = score;
        bestKey = key;
      }
    }

    if (!bestKey) return null;
    const [r, g, b] = bestKey.split(",").map(Number);
    return { r, g, b };
  };

  const applyLogoBackground = (wrap) => {
    const img = wrap.querySelector("img");
    if (!img) return;
    const color = pickEdgeColor(img);
    if (!color) return;

    const bg = `rgb(${color.r} ${color.g} ${color.b})`;
    const border = `rgb(${Math.max(0, Math.round(color.r * 0.82))} ${Math.max(0, Math.round(color.g * 0.82))} ${Math.max(0, Math.round(color.b * 0.82))})`;
    wrap.style.backgroundColor = bg;
    wrap.style.borderColor = border;
  };

  const wraps = document.querySelectorAll(".case__logo-wrap");
  wraps.forEach((wrap) => {
    const img = wrap.querySelector("img");
    if (!img) return;
    if (img.complete) {
      applyLogoBackground(wrap);
    } else {
      img.addEventListener("load", () => applyLogoBackground(wrap), { once: true });
    }
  });
</script>
