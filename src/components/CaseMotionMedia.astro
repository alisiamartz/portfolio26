---
import { withBasePath } from "../utils/path";

const {
  src,
  alt = "",
  caption = "",
  type = "auto", // auto | video | image | embed
  loop = true,
  autoplay = true,
  muted = true,
  controls = true,
} = Astro.props;

const normalizedSrc = String(src ?? "").toLowerCase();
const isVimeo = normalizedSrc.includes("vimeo.com");
const base = import.meta.env.BASE_URL;
const resolvedSrc = withBasePath(src, base);
const inferredType =
  type !== "auto"
    ? type
    : isVimeo
      ? "embed"
      : normalizedSrc.endsWith(".gif")
      ? "image"
      : "video";
---

<figure class="case-motion-media">
  {inferredType === "embed" ? (
    <div class="case-motion-media__embed">
      <iframe
        title={alt || "Vimeo player"}
        src={resolvedSrc}
        frameborder="0"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
        allowfullscreen
      />
    </div>
  ) : inferredType === "video" ? (
    <video src={resolvedSrc} controls={controls} autoplay={autoplay} loop={loop} muted={muted} playsinline />
  ) : (
    <img src={resolvedSrc} alt={alt} loading="lazy" />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .case-motion-media {
    margin: 28px 0;
  }

  .case-motion-media video,
  .case-motion-media img {
    width: 100%;
    display: block;
    border-radius: 12px;
    border: 1px solid rgba(17, 17, 17, 0.12);
    background: #fff;
  }

  .case-motion-media__embed {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(17, 17, 17, 0.12);
    background: #000;
  }

  .case-motion-media__embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  figcaption {
    margin-top: 10px;
    font-size: 0.9rem;
    color: rgba(17, 17, 17, 0.62);
    text-align: center;
  }
</style>
