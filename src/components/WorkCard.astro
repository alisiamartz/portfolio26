---
import Pill from "./Pill.astro";
import { getTagStyles } from "../utils/tagStyles";
import { withBasePath } from "../utils/path";
const { href, title, description, tags = [], roles = [], logoSrc, logoAlt = "" } = Astro.props;
const base = import.meta.env.BASE_URL;
const rolesText = roles.length > 0 ? roles.join(" • ") : null;
const visibleTags = (() => {
  if (!tags.includes("Confidential")) return tags.slice(0, 3);

  const firstFour = tags.slice(0, 4);
  if (firstFour.includes("Confidential")) return firstFour;

  return [...tags.slice(0, 3).filter((tag) => tag !== "Confidential"), "Confidential"];
})();
const visibleTagStyles = getTagStyles(visibleTags);
const resolvedLogoSrc = logoSrc
  ? withBasePath(logoSrc.startsWith("/") ? logoSrc : `/${logoSrc}`, base)
  : undefined;
const resolvedHref = withBasePath(href, base);
---

<a href={resolvedHref} class="card cardHover block p-6 js-bouncy-workcard">
  <div class="space-y-3">
    <div class="flex items-start justify-between gap-3">
      <div class="text-lg font-semibold tracking-tight workcard__title">{title}</div>
      {resolvedLogoSrc && (
        <div class="js-workcard-logo-wrap h-8 w-8 shrink-0 rounded-[8px] border border-black/10 bg-black/5 flex items-center justify-center">
          <img src={resolvedLogoSrc} alt={logoAlt} class="h-6 w-6 object-contain" loading="lazy" />
        </div>
      )}
    </div>

    <div class="text-sm muted">{description}</div>

    {rolesText && <div class="text-sm muted font-semibold">{rolesText}</div>}

    <div class="flex flex-wrap gap-2 pt-2">
      {visibleTags.map((t) => {
        const colors = visibleTagStyles[t];
        return (
          <Pill
            text={t}
            className="js-bouncy-pill"
            style={`background:${colors.bg};border-color:${colors.border};color:${colors.text};`}
          />
        );
      })}
    </div>
  </div>
</a>

<script>
  const quantizeChannel = (value) => Math.round(value / 8) * 8;
  const hasMeaningfulTransparency = (pixels, w, h) => {
    const totalPixels = w * h;
    const stride = totalPixels > 40000 ? 16 : 4;
    let sampled = 0;
    let transparent = 0;

    for (let i = 3; i < pixels.length; i += stride * 4) {
      sampled += 1;
      if (pixels[i] < 245) transparent += 1;
    }

    return sampled > 0 && transparent / sampled > 0.01;
  };

  const pickEdgeColor = (img) => {
    const w = img.naturalWidth;
    const h = img.naturalHeight;
    if (!w || !h) return null;

    const canvas = document.createElement("canvas");
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext("2d", { willReadFrequently: true });
    if (!ctx) return null;

    ctx.drawImage(img, 0, 0, w, h);
    let imageData;
    try {
      imageData = ctx.getImageData(0, 0, w, h).data;
    } catch {
      return null;
    }
    if (hasMeaningfulTransparency(imageData, w, h)) return null;

    const bins = new Map();
    const addPixel = (x, y) => {
      const i = (y * w + x) * 4;
      const a = imageData[i + 3];
      if (a < 24) return;
      const r = quantizeChannel(imageData[i]);
      const g = quantizeChannel(imageData[i + 1]);
      const b = quantizeChannel(imageData[i + 2]);
      const key = `${r},${g},${b}`;
      bins.set(key, (bins.get(key) ?? 0) + a);
    };

    for (let x = 0; x < w; x++) {
      addPixel(x, 0);
      addPixel(x, h - 1);
    }
    for (let y = 1; y < h - 1; y++) {
      addPixel(0, y);
      addPixel(w - 1, y);
    }

    if (bins.size === 0) return null;

    let bestKey = null;
    let bestScore = -1;
    for (const [key, score] of bins) {
      if (score > bestScore) {
        bestScore = score;
        bestKey = key;
      }
    }

    if (!bestKey) return null;
    const [r, g, b] = bestKey.split(",").map(Number);
    return { r, g, b };
  };

  const applyLogoBackground = (wrap) => {
    const img = wrap.querySelector("img");
    if (!img) return;
    const color = pickEdgeColor(img);
    if (!color) return;

    const bg = `rgb(${color.r} ${color.g} ${color.b})`;
    const border = `rgb(${Math.max(0, Math.round(color.r * 0.82))} ${Math.max(0, Math.round(color.g * 0.82))} ${Math.max(0, Math.round(color.b * 0.82))})`;
    wrap.style.backgroundColor = bg;
    wrap.style.borderColor = border;
  };

  const wraps = document.querySelectorAll(".js-workcard-logo-wrap");
  wraps.forEach((wrap) => {
    const img = wrap.querySelector("img");
    if (!img) return;
    if (img.complete) {
      applyLogoBackground(wrap);
    } else {
      img.addEventListener("load", () => applyLogoBackground(wrap), { once: true });
    }
  });
</script>

<style>
  .js-bouncy-workcard {
    transition-property: border-color, box-shadow, background-color, color, opacity;
  }

  .workcard__title {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    transition: text-decoration-color 180ms ease;
  }

  .js-bouncy-workcard:hover .workcard__title,
  .js-bouncy-workcard:focus-visible .workcard__title {
    text-decoration-color: color-mix(in oklab, var(--pop1) 55%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .workcard__title {
      transition: none;
    }
  }
</style>
