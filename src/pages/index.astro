---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import ParticleNameMark from "../components/ParticleNameMark.astro";
import { getCollection } from "astro:content";
import { compareWorkByMostRecent } from "../utils/workSort";
import { withBasePath } from "../utils/path";
import { getTagStyle } from "../utils/tagStyles";

const work = await getCollection("work");
const listedWork = work.filter((e) => e.data.listed !== false);
const sortedWork = [...listedWork].sort(compareWorkByMostRecent);
const featured = sortedWork
  .filter((e) => e.data.featured)
  .slice(0, 6);
const base = import.meta.env.BASE_URL;
const skills = [
  {
    name: "Prototyping & interaction systems",
    subtitle: "Turning rough ideas into testable experiences.",
    topicTag: "Prototyping",
    weight: 2.2,
    span: 3,
    height: 3.1
  },
  {
    name: "Product design & UX",
    subtitle: "Designing clarity from complex product flows.",
    topicTag: "Design",
    weight: 2.0,
    span: 3,
    height: 2.8
  },
  {
    name: "Creative direction & storytelling",
    subtitle: "Framing concepts into memorable narratives.",
    topicTag: "Interactive Narrative",
    weight: 1.85,
    span: 2,
    height: 2.5
  },
  {
    name: "Experiential / event design",
    subtitle: "Crafting spaces people can move through.",
    topicTag: "Installation",
    weight: 1.65,
    span: 2,
    height: 2.2
  },
  {
    name: "Video / content creation",
    subtitle: "Fast stories for launch, social, and demos.",
    topicTag: "Hackathon",
    weight: 1.4,
    span: 1,
    height: 1.9
  },
  {
    name: "Immersive/XR",
    subtitle: "Interaction ideas built in three dimensions.",
    topicTag: "XR",
    weight: 1.6,
    span: 2,
    height: 2.25
  },
  {
    name: "Game Design",
    subtitle: "Systems, pacing, and playful mechanics.",
    topicTag: "Game",
    weight: 1.3,
    span: 2,
    height: 1.85
  },
  {
    name: "Unity, C#",
    subtitle: "Shipping prototypes with engine-level control.",
    topicTag: "Development",
    weight: 1.2,
    span: 1,
    height: 1.55
  },
  {
    name: "Sewing + Embroidery",
    subtitle: "Physical craft folded into digital making.",
    topicTag: "Installation",
    weight: 1.1,
    span: 1,
    height: 1.35
  }
];
---

<BaseLayout
  title="Alisia Martinez — Experience Designer + Prototyper"
  description="I make ideas a reality."
>
  <!-- HERO -->

  <div class="grid md:grid-cols-[1fr_auto_1fr] gap-10 items-start">
    <section class="space-y-6">
      <ParticleNameMark
        as="h1"
        text="I turn ideas into reality."
        height={150}
        density={6}
        idleHtml={true}
        className="max-w-xl"
        textClassName="h1"
      />

      <p class="muted text-lg max-w-xl">
        Experience Designer + Prototyper + Creator
      </p>

      <div class="flex gap-3">
        <a class="btn" href={withBasePath("/work", base)}>View work</a>
       <!-- <a class="btnGhost" href="/watch">Watch</a> -->
      </div>
    </section>

    <!-- IDKKK Vertical divider (deck-like) -->
    <div class="hidden md:block w-px bg-black/10 self-stretch"></div>

    <section class="border border-white/10 rounded-xl p-8">
      <div class="label">Point of view</div>
      <div class="mt-4 text-lg max-w-3xl">
        Experience designer + prototyper across interaction systems, XR, and story-led work.
        I turn ambiguity into artifacts: prototypes, systems, and story-shaped experiences, so people can react to something real.
      </div>
    </section>
  </div>

    <!-- Divider -->
  <div class="divider-dots my-16" />

    <!-- SKILLS -->
  <section class="space-y-4">
    <h2 class="h2">Skills</h2>
    <p class="muted text-sm">Move your cursor to stir things up.</p>

    <div class="skills-field card border-black/15 bg-white/80 p-4 md:p-6">
      <ul class="skills-grid">
        {skills.map((skill, idx) => (
          (() => {
            const colors = getTagStyle(skill.topicTag);
            return (
          <li
            class="skill-item"
            style={`--w:${skill.weight};--span:${skill.span};--h:${skill.height};--tilt:${idx % 3 === 0 ? "-0.8deg" : idx % 3 === 1 ? "0.65deg" : "-0.25deg"};--skill-bg:${colors.bg};--skill-border:${colors.border};--skill-text:${colors.text};`}
            data-skill-item
          >
            <button
              type="button"
              class="skill-chip"
              data-skill-chip
              data-index={idx}
              aria-pressed="false"
            >
              <span class="skill-title">{skill.name}</span>
              <span class="skill-subtitle" data-skill-subtitle>{skill.subtitle}</span>
            </button>
          </li>
            );
          })()
        ))}
      </ul>
    </div>
  </section>

    <!-- Divider -->
  <div class="divider-dots my-16" />

    <!-- SELECTED WORK -->
  <section class="space-y-6">
    <div class="flex items-end justify-between">
      <h2 class="h2">Selected work</h2>
      <a class="link-accent" href={withBasePath("/work", base)}>All work ></a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {featured.map((e) => (
        <WorkCard
          href={`/work/${e.slug}`}
          title={e.data.title}
          description={e.data.description}
          tags={e.data.tags}
          roles={e.data.roles}
          logoSrc={e.data.logoSrc}
          logoAlt={e.data.logoAlt ?? ""}
        />
      ))}
    </div>
  </section>

    <!-- Divider -->
  <div class="divider-dots my-16" />


</BaseLayout>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    min-height: clamp(4rem, calc(2.8rem + (var(--h) * 0.95rem)), 7rem);
  }

  .skill-chip {
    --mx: 0px;
    --my: 0px;
    --lift: 0px;
    --size: clamp(0.85rem, calc(0.76rem + (var(--w) * 0.09rem)), 1.02rem);
    border: 1px solid var(--skill-border, color-mix(in oklab, var(--ink) 18%, transparent));
    background: var(--skill-bg, color-mix(in oklab, white 92%, var(--cream)));
    color: var(--skill-text, var(--ink));
    box-shadow: 0 1px 0 rgba(17, 17, 17, 0.08), 0 3px 8px rgba(17, 17, 17, 0.06);
    border-radius: 1rem;
    font-size: var(--size);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
    width: 100%;
    min-height: inherit;
    text-align: left;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.45rem;
    padding: clamp(0.55rem, calc(0.43rem + (var(--w) * 0.08rem)), 0.8rem)
      clamp(0.8rem, calc(0.62rem + (var(--w) * 0.18rem)), 1.2rem);
    text-wrap: pretty;
    transform: translate3d(var(--mx), calc(var(--my) + var(--lift)), 0) rotate(var(--tilt));
    transition: transform 260ms cubic-bezier(0.2, 0.7, 0.2, 1),
      box-shadow 220ms ease,
      border-color 220ms ease,
      text-decoration-color 220ms ease;
    will-change: transform;
  }

  .skill-title {
    display: block;
  }

  .skill-chip:hover,
  .skill-chip:focus-visible {
    --lift: -4px;
    border-color: color-mix(in oklab, var(--skill-text, var(--ink)) 28%, var(--skill-border, transparent));
    box-shadow: 0 8px 14px rgba(17, 17, 17, 0.12);
  }

  .skill-chip:hover .skill-title,
  .skill-chip:focus-visible .skill-title {
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--skill-text, var(--pop1)) 65%, transparent);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }

    .skill-item {
      grid-column: span var(--span);
    }
  }

  .skill-chip:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--skill-text, var(--pop1)) 45%, transparent);
    outline-offset: 2px;
  }

  .skill-chip.is-active {
    border-color: color-mix(in oklab, var(--skill-text, var(--ink)) 36%, var(--skill-border, transparent));
    box-shadow: 0 6px 12px rgba(17, 17, 17, 0.1);
  }

  .skill-subtitle {
    font-size: 0.75rem;
    color: rgb(17 17 17 / 0.65);
    max-width: 24ch;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(-3px);
    transition: max-height 250ms ease, opacity 200ms ease, transform 250ms ease;
  }

  .skill-chip:hover .skill-subtitle,
  .skill-chip:focus-visible .skill-subtitle,
  .skill-chip.is-active .skill-subtitle {
    max-height: 4rem;
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-chip {
      transition: box-shadow 220ms ease, border-color 220ms ease,
        text-decoration-color 220ms ease;
      transform: none;
    }
  }
</style>

<script>
  const clamp = (v, min, max) => Math.min(max, Math.max(min, v));

  document.querySelectorAll(".skills-field").forEach((root) => {
    const chips = Array.from(root.querySelectorAll("[data-skill-chip]"));
    if (!chips.length) return;

    const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    let reducedMotion = reduceMotionQuery.matches;
    let pointerX = 0;
    let pointerY = 0;
    let pointerActive = false;
    let rafId = null;

    const chipState = chips.map((chip, idx) => ({
      chip,
      x: 0,
      y: 0,
      tx: 0,
      ty: 0,
      polarity: idx % 2 === 0 ? 1 : -1
    }));

    const setActive = (activeIdx) => {
      chipState.forEach((entry, idx) => {
        const isActive = idx === activeIdx;
        entry.chip.classList.toggle("is-active", isActive);
        entry.chip.setAttribute("aria-pressed", String(isActive));
      });
    };

    const clearMotion = () => {
      chipState.forEach((entry) => {
        entry.x = 0;
        entry.y = 0;
        entry.tx = 0;
        entry.ty = 0;
        entry.chip.style.setProperty("--mx", "0px");
        entry.chip.style.setProperty("--my", "0px");
      });
    };

    const updateTargets = () => {
      if (!pointerActive || reducedMotion) {
        chipState.forEach((entry) => {
          entry.tx = 0;
          entry.ty = 0;
        });
        return;
      }

      chipState.forEach((entry) => {
        const rect = entry.chip.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = cx - pointerX;
        const dy = cy - pointerY;
        const dist = Math.hypot(dx, dy) || 1;
        const influence = 170;
        const n = clamp(1 - dist / influence, 0, 1);
        const maxOffset = 12.5;
        const magnitude = n * maxOffset * entry.polarity;
        entry.tx = clamp((dx / dist) * magnitude, -14, 14);
        entry.ty = clamp((dy / dist) * magnitude, -14, 14);
      });
    };

    const animate = () => {
      let hasMotion = false;
      chipState.forEach((entry) => {
        entry.x += (entry.tx - entry.x) * 0.16;
        entry.y += (entry.ty - entry.y) * 0.16;
        if (Math.abs(entry.tx - entry.x) > 0.05 || Math.abs(entry.ty - entry.y) > 0.05) {
          hasMotion = true;
        }
        entry.chip.style.setProperty("--mx", `${entry.x.toFixed(2)}px`);
        entry.chip.style.setProperty("--my", `${entry.y.toFixed(2)}px`);
      });

      if (hasMotion || pointerActive) {
        rafId = requestAnimationFrame(animate);
      } else {
        rafId = null;
      }
    };

    const startRaf = () => {
      if (rafId || reducedMotion) return;
      rafId = requestAnimationFrame(animate);
    };

    const onPointerMove = (event) => {
      pointerX = event.clientX;
      pointerY = event.clientY;
      pointerActive = true;
      updateTargets();
      startRaf();
    };

    const onPointerLeave = () => {
      pointerActive = false;
      setActive(-1);
      updateTargets();
      startRaf();
    };

    const onChipClick = (event) => {
      const clicked = event.currentTarget;
      const idx = chipState.findIndex((entry) => entry.chip === clicked);
      if (idx === -1) return;
      const isActive = clicked.classList.contains("is-active");
      setActive(isActive ? -1 : idx);
    };

    const onReducedMotionChange = (event) => {
      reducedMotion = event.matches;
      if (reducedMotion) {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
        clearMotion();
        return;
      }
      updateTargets();
      startRaf();
    };

    root.addEventListener("pointermove", onPointerMove);
    root.addEventListener("pointerleave", onPointerLeave);
    reduceMotionQuery.addEventListener("change", onReducedMotionChange);
    chipState.forEach((entry) => {
      entry.chip.addEventListener("click", onChipClick);
    });

    window.addEventListener("beforeunload", () => {
      if (rafId) cancelAnimationFrame(rafId);
      reduceMotionQuery.removeEventListener("change", onReducedMotionChange);
    });
  });
</script>
