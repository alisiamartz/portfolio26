---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import { getCollection } from "astro:content";
import { compareWorkByMostRecent } from "../utils/workSort";
import { withBasePath } from "../utils/path";

const work = await getCollection("work");
const listedWork = work.filter((e) => e.data.listed !== false);
const sortedWork = [...listedWork].sort(compareWorkByMostRecent);
const featured = sortedWork
  .filter((e) => e.data.featured)
  .slice(0, 6);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Alisia Martinez — Experience Designer + Prototyper"
  description="I make ideas a reality."
>
  <!-- HERO -->

  <section class="grid md:grid-cols-[1fr_auto_1fr] gap-10 items-start">
        
    <!-- Left -->
    <div class="space-y-6">
      <h1 class="h1">
        I turn ideas into reality.
      </h1>

      <p class="muted text-lg max-w-xl"> 
        Experience Designer + Prototyper + Creator
      </p>

      <div class="flex gap-3">
        <a class="btn" href={withBasePath("/work", base)}>View work</a>
       <!-- <a class="btnGhost" href="/watch">Watch</a> --> 
      </div>
    </div>

        <!-- IDKKK Vertical divider (deck-like) -->
    <div class="hidden md:block w-px bg-black/10 self-stretch"></div>

        <!-- Right     <div class="border border-white/10 rounded-xl p-6 text-white/70">
-->
            <!-- POV -->
  <section class="border border-white/10 rounded-xl p-8">
    <div class="label">Point of view</div>
    <div class="mt-4 text-lg max-w-3xl">
      I turn ambiguity into artifacts: prototypes, systems, and story-shaped experiences, so people can react to something real.
    </div>

    <div class="mt-10 card p-6">
      <div class="label">What I Build</div>
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <a class="card cardHover p-4" href={withBasePath("/work?tag=Prototyping", base)}>Interactive / Prototypes</a>
           <a class="card cardHover p-4" href={withBasePath("/work?tag=XR%2FVR", base)}>Immersive / XR</a>
        <a class="card cardHover p-4" href={withBasePath("/watch", base)}>Stories / Films</a>
        <a class="card cardHover p-4" href={withBasePath("/playground", base)}>Live Experiences</a>
      </div>
    </div>
      </section>

  </section>

    <!-- Divider -->
  <div class="divider-dots my-16" />

    <!-- SELECTED WORK -->
  <section class="space-y-6">
    <div class="flex items-end justify-between">
      <h2 class="h2">Selected work</h2>
      <a class="link-accent" href={withBasePath("/work", base)}>All work ></a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {featured.map((e) => (
        <WorkCard
          href={`/work/${e.slug}`}
          title={e.data.title}
          description={e.data.description}
          tags={e.data.tags}
          roles={e.data.roles}
          logoSrc={e.data.logoSrc}
          logoAlt={e.data.logoAlt ?? ""}
        />
      ))}
    </div>
  </section>

    <!-- Divider -->
  <div class="divider-dots my-16" />


</BaseLayout>
