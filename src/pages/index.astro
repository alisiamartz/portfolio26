---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import ParticleNameMark from "../components/ParticleNameMark.astro";
import { getCollection } from "astro:content";
import { compareWorkByMostRecent } from "../utils/workSort";
import { withBasePath } from "../utils/path";

const work = await getCollection("work");
const listedWork = work.filter((e) => e.data.listed !== false);
const sortedWork = [...listedWork].sort(compareWorkByMostRecent);
const featured = sortedWork
  .filter((e) => e.data.featured)
  .slice(0, 6);
const base = import.meta.env.BASE_URL;
const skills = [
  {
    name: "Prototyping & interaction systems",
    subtitle: "Turning rough ideas into testable experiences.",
    marker: "square",
    accent: "Prototyping"
  },
  {
    name: "Product design & UX",
    subtitle: "Designing clarity from complex product flows.",
    marker: "circle",
    accent: "UX"
  },
  {
    name: "Creative direction & storytelling",
    subtitle: "Framing concepts into memorable narratives.",
    marker: "triangle",
    accent: "storytelling"
  },
  {
    name: "Experiential / event design",
    subtitle: "Crafting spaces people can move through.",
    marker: "diamond",
    accent: "event"
  },
  {
    name: "Video / content creation",
    subtitle: "Fast stories for launch, social, and demos.",
    marker: "plus",
    accent: "Video"
  },
  {
    name: "Immersive/XR",
    subtitle: "Interaction ideas built in three dimensions.",
    marker: "ring",
    accent: "XR"
  },
  {
    name: "Game Design",
    subtitle: "Systems, pacing, and playful mechanics.",
    marker: "star",
    accent: "Game"
  },
  {
    name: "Unity, C#",
    subtitle: "Shipping prototypes with engine-level control.",
    marker: "bar",
    accent: "Unity"
  },
  {
    name: "Sewing + Embroidery",
    subtitle: "Physical craft folded into digital making.",
    marker: "dot",
    accent: "Sewing"
  }
];
---

<BaseLayout
  title="Alisia Martinez — Experience Designer + Prototyper"
  description="I make ideas a reality."
>
  <!-- HERO -->

  <div class="grid md:grid-cols-[1fr_auto_1fr] gap-10 items-start">
    <section class="space-y-6">
      <ParticleNameMark
        as="h1"
        text="I turn ideas into reality."
        height={150}
        density={6}
        idleHtml={true}
        className="max-w-xl -mb-3"
        textClassName="h1"
      />

      <p class="muted text-lg max-w-xl">
        Experience Designer + Prototyper + Creator
      </p>

      <div class="flex gap-3">
        <a class="btn" href={withBasePath("/work", base)}>View work</a>
       <!-- <a class="btnGhost" href="/watch">Watch</a> -->
      </div>

      <!-- <section class="border border-white/10 rounded-xl p-6 md:p-7">
        <div class="label">Point of view</div>
        <div class="mt-4 text-lg max-w-3xl">
          Experience designer + prototyper across interaction systems, XR, and story-led work.
          I turn ambiguity into artifacts: prototypes, systems, and story-shaped experiences, so people can react to something real.
        </div>
      </section>-->
    </section

    <!-- IDKKK Vertical divider (deck-like) -->
    <div class="hidden md:block w-px bg-black/10 self-stretch"></div>

    <section class="skills-stack skills-stack-rail space-y-3" data-skills-stack>
      <h2 class="h2">Skills</h2>
      <!-- <p class="muted text-sm">Move your cursor—type reacts.</p> -->

      <div class="skills-field card border-black/15 bg-white/80 p-4 md:p-5">
        <ul class="kinetic-stack" data-skills-list>
          {skills.map((skill, idx) => (
            <li class="skill-row" data-skill-row>
              <button
                type="button"
                class="skill-row-btn"
                data-skill-row-btn
                data-index={idx}
                aria-pressed="false"
              >
                <span class="skill-marker" data-marker={skill.marker} aria-hidden="true"></span>
                <span class="skill-copy">
                  <span class="skill-label" data-skill-label>
                    {skill.name}
                  </span>
                  <span class="skill-subline" data-skill-subtitle>{skill.subtitle}</span>
                </span>
              </button>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>

    <!-- Divider -->
  <div class="divider-dots my-16" />

    <!-- SELECTED WORK -->
  <section class="space-y-6">
    <div class="flex items-end justify-between">
      <h2 class="h2">Selected work</h2>
      <a class="link-accent" href={withBasePath("/work", base)}>All work ></a>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      {featured.map((e) => (
        <WorkCard
          href={`/work/${e.slug}`}
          title={e.data.title}
          description={e.data.description}
          tags={e.data.tags}
          roles={e.data.roles}
          logoSrc={e.data.logoSrc}
          logoAlt={e.data.logoAlt ?? ""}
        />
      ))}
    </div>
  </section>

    <!-- Divider -->
  <div class="divider-dots my-16" />


</BaseLayout>

<style>
  .skills-stack .skills-field {
    padding-block: clamp(1.15rem, 1rem + 0.8vw, 1.8rem);
  }

  .skills-stack-rail {
    width: min(100%, 27rem);
    justify-self: stretch;
  }

  .skills-stack-rail .skills-field {
    padding-inline: clamp(0.72rem, 0.62rem + 0.35vw, 0.95rem);
  }

  .kinetic-stack {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .skill-row {
    border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
  }

  .skill-row:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
  }

  .skill-row-btn {
    --row-shift: 0px;
    --row-track: 0.002em;
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--ink);
    padding: clamp(0.66rem, 0.58rem + 0.3vw, 0.85rem) 0.1rem;
    text-align: left;
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    align-items: start;
    gap: 0.68rem;
    transform: translate3d(var(--row-shift), 0, 0);
    transition: transform 220ms cubic-bezier(0.2, 0.65, 0.2, 1), background-color 200ms ease;
  }

  .skill-marker {
    width: 0.62rem;
    height: 0.62rem;
    margin-top: 0.37rem;
    border: 1px solid color-mix(in oklab, var(--ink) 35%, transparent);
    background: color-mix(in oklab, white 84%, var(--cream));
    transition: transform 230ms cubic-bezier(0.2, 0.7, 0.2, 1), background-color 180ms ease;
  }

  .skill-marker[data-marker="circle"] { border-radius: 999px; }
  .skill-marker[data-marker="diamond"] { transform: rotate(45deg); }
  .skill-marker[data-marker="triangle"] {
    width: 0;
    height: 0;
    margin-top: 0.25rem;
    border-left: 0.4rem solid transparent;
    border-right: 0.4rem solid transparent;
    border-bottom: 0.72rem solid color-mix(in oklab, var(--ink) 32%, transparent);
    border-top: 0;
    background: transparent;
  }
  .skill-marker[data-marker="plus"] {
    border: 0;
    width: 0.72rem;
    height: 0.72rem;
    position: relative;
    background: transparent;
  }
  .skill-marker[data-marker="plus"]::before,
  .skill-marker[data-marker="plus"]::after {
    content: "";
    position: absolute;
    inset: 0;
    margin: auto;
    background: color-mix(in oklab, var(--ink) 38%, transparent);
  }
  .skill-marker[data-marker="plus"]::before {
    width: 0.72rem;
    height: 1px;
  }
  .skill-marker[data-marker="plus"]::after {
    width: 1px;
    height: 0.72rem;
  }
  .skill-marker[data-marker="ring"] {
    border-radius: 999px;
    background: transparent;
    border-width: 2px;
  }
  .skill-marker[data-marker="star"] {
    clip-path: polygon(50% 0, 61% 36%, 98% 36%, 68% 57%, 79% 92%, 50% 71%, 21% 92%, 32% 57%, 2% 36%, 39% 36%);
  }
  .skill-marker[data-marker="bar"] {
    width: 0.22rem;
    height: 0.86rem;
    border-radius: 999px;
  }
  .skill-marker[data-marker="dot"] {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
  }

  .skill-copy {
    min-width: 0;
    position: relative;
    padding-bottom: 0.05rem;
  }

  .skill-label {
    position: relative;
    z-index: 1;
    display: inline-block;
    font-size: clamp(0.88rem, 0.84rem + 0.2vw, 0.98rem);
    font-weight: 420;
    letter-spacing: var(--row-track);
    line-height: 1.3;
    transition: font-weight 170ms ease, letter-spacing 190ms ease;
    text-wrap: pretty;
  }

  .skill-label::before {
    content: "";
    position: absolute;
    left: -0.15rem;
    right: -0.15rem;
    bottom: -0.02rem;
    height: 0.9em;
    background: color-mix(in oklab, var(--butter) 30%, transparent);
    transform: scaleX(0.18) skewX(-8deg);
    transform-origin: left;
    opacity: 0;
    z-index: -1;
    transition: transform 260ms cubic-bezier(0.2, 0.7, 0.2, 1), opacity 200ms ease;
  }

  .skill-label::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.14rem;
    width: 100%;
    height: 1.5px;
    background: color-mix(in oklab, var(--pop1) 72%, transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .skill-subline {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.72rem;
    color: color-mix(in oklab, var(--ink) 68%, transparent);
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(-3px);
    transition: max-height 220ms ease, opacity 190ms ease, transform 220ms ease;
  }

  .skill-row-btn:hover,
  .skill-row-btn:focus-visible,
  .skill-row-btn.is-active {
    background: color-mix(in oklab, white 45%, transparent);
  }

  .skill-row-btn:hover .skill-label,
  .skill-row-btn:focus-visible .skill-label,
  .skill-row-btn.is-active .skill-label {
    font-weight: 500;
    letter-spacing: 0;
  }

  .skill-row-btn:hover .skill-label::before,
  .skill-row-btn:focus-visible .skill-label::before,
  .skill-row-btn.is-active .skill-label::before {
    transform: scaleX(1) skewX(-8deg);
    opacity: 1;
  }

  .skill-row-btn:hover .skill-label::after,
  .skill-row-btn:focus-visible .skill-label::after,
  .skill-row-btn.is-active .skill-label::after {
    transform: scaleX(1);
  }

  .skill-row-btn:hover .skill-marker,
  .skill-row-btn:focus-visible .skill-marker,
  .skill-row-btn.is-active .skill-marker {
    transform: translateY(1px) rotate(14deg) scale(1.07);
    background: color-mix(in oklab, var(--pop1) 12%, white);
  }

  .skill-row-btn:hover .skill-marker[data-marker="triangle"],
  .skill-row-btn:focus-visible .skill-marker[data-marker="triangle"],
  .skill-row-btn.is-active .skill-marker[data-marker="triangle"] {
    border-bottom-color: color-mix(in oklab, var(--pop1) 42%, var(--ink));
    transform: translateY(1px) rotate(7deg);
    background: transparent;
  }

  .skill-row-btn.is-active .skill-subline,
  .skill-row-btn:hover .skill-subline,
  .skill-row-btn:focus-visible .skill-subline {
    max-height: 2.8rem;
    opacity: 1;
    transform: translateY(0);
  }

  .skill-row-btn:focus-visible {
    outline: 2px solid color-mix(in oklab, var(--pop1) 55%, transparent);
    outline-offset: -2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-row-btn {
      transition: background-color 200ms ease;
      transform: none;
    }

    .skill-marker,
    .skill-label::before,
    .skill-label::after,
    .skill-subline {
      transition: none;
    }
  }

  @media (hover: none) {
    .skill-row-btn:hover .skill-subline {
      max-height: 0;
      opacity: 0;
      transform: translateY(-3px);
    }
  }
</style>

<script>
  const clamp = (v, min, max) => Math.min(max, Math.max(min, v));

  document.querySelectorAll("[data-skills-stack]").forEach((root) => {
    const rows = Array.from(root.querySelectorAll("[data-skill-row-btn]"));
    if (!rows.length) return;

    const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    let reducedMotion = reduceMotionQuery.matches;
    const supportsHover = window.matchMedia("(hover: hover)").matches;
    let pointerX = 0;
    let pointerY = 0;
    let pointerActive = false;
    let rafId = null;

    const rowState = rows.map((row) => ({
      row,
      x: 0,
      tx: 0,
      track: 0.002
    }));

    const setActive = (activeIdx) => {
      rowState.forEach((entry, idx) => {
        const isActive = idx === activeIdx;
        entry.row.classList.toggle("is-active", isActive);
        entry.row.setAttribute("aria-pressed", String(isActive));
      });
    };

    const clearMotion = () => {
      rowState.forEach((entry) => {
        entry.x = 0;
        entry.tx = 0;
        entry.track = 0.002;
        entry.row.style.setProperty("--row-shift", "0px");
        entry.row.style.setProperty("--row-track", "0.002em");
      });
    };

    const updateTargets = () => {
      if (!pointerActive || reducedMotion || !supportsHover) {
        rowState.forEach((entry) => {
          entry.tx = 0;
          entry.track = 0.002;
        });
        return;
      }

      rowState.forEach((entry) => {
        const rect = entry.row.getBoundingClientRect();
        const cy = rect.top + rect.height / 2;
        const dy = cy - pointerY;
        const influence = 185;
        const n = clamp(1 - Math.abs(dy) / influence, 0, 1);
        const dir = dy > 0 ? -1 : 1;
        entry.tx = clamp(n * 12 * dir, -10, 10);
        entry.track = 0.002 + n * 0.012;
      });
    };

    const animate = () => {
      let hasMotion = false;
      rowState.forEach((entry) => {
        entry.x += (entry.tx - entry.x) * 0.16;
        const currentTrack = parseFloat(entry.row.style.getPropertyValue("--row-track")) || 0.002;
        const nextTrack = currentTrack + (entry.track - currentTrack) * 0.2;
        if (Math.abs(entry.tx - entry.x) > 0.05 || Math.abs(entry.track - nextTrack) > 0.0005) {
          hasMotion = true;
        }
        entry.row.style.setProperty("--row-shift", `${entry.x.toFixed(2)}px`);
        entry.row.style.setProperty("--row-track", `${nextTrack.toFixed(4)}em`);
      });

      if (hasMotion || pointerActive) {
        rafId = requestAnimationFrame(animate);
      } else {
        rafId = null;
      }
    };

    const startRaf = () => {
      if (rafId || reducedMotion || !supportsHover) return;
      rafId = requestAnimationFrame(animate);
    };

    const onPointerMove = (event) => {
      if (!supportsHover) return;
      pointerX = event.clientX;
      pointerY = event.clientY;
      pointerActive = true;
      updateTargets();
      startRaf();
    };

    const onPointerLeave = () => {
      pointerActive = false;
      updateTargets();
      startRaf();
    };

    const onRowClick = (event) => {
      const clicked = event.currentTarget;
      const idx = rowState.findIndex((entry) => entry.row === clicked);
      if (idx === -1) return;
      const isActive = clicked.classList.contains("is-active");
      setActive(isActive ? -1 : idx);
    };

    const onReducedMotionChange = (event) => {
      reducedMotion = event.matches;
      if (reducedMotion) {
        if (rafId) cancelAnimationFrame(rafId);
        rafId = null;
        clearMotion();
        return;
      }
      updateTargets();
      startRaf();
    };

    if (supportsHover) {
      root.addEventListener("pointermove", onPointerMove);
      root.addEventListener("pointerleave", onPointerLeave);
    }
    reduceMotionQuery.addEventListener("change", onReducedMotionChange);
    rowState.forEach((entry) => {
      entry.row.addEventListener("click", onRowClick);
    });

    window.addEventListener("beforeunload", () => {
      if (rafId) cancelAnimationFrame(rafId);
      reduceMotionQuery.removeEventListener("change", onReducedMotionChange);
    });
  });
</script>
