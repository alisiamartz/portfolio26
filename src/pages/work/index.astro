---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getCollection } from "astro:content";
import { compareWorkByMostRecent } from "../../utils/workSort";

const work = await getCollection("work");
const listedWork = work.filter((e) => e.data.listed !== false);
const sortedWork = [...listedWork].sort(compareWorkByMostRecent);

// read optional prefilter: /work?tag=Prototyping
const tag = Astro.url.searchParams.get("tag");
const list = tag
  ? sortedWork.filter((e) => e.data.tags.includes(tag))
  : sortedWork;

const allTags = Array.from(new Set(listedWork.flatMap((e) => e.data.tags))).sort();
---

<BaseLayout title="Work — Alisia Martinez" description="Selected case studies and experiments.">
  <section class="mx-auto w-full max-w-[82rem] space-y-8 md:space-y-10">
    <header class="space-y-3 text-center">
      <h1 class="h1">Work</h1>
      <p class="mx-auto max-w-xl text-sm uppercase tracking-[0.2em] text-black/45">
        Projects across prototyping, XR, interaction systems, and story-led experiences.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-4 pt-4">
      {list.map((e) => (
        <WorkCard
          href={`/work/${e.slug}`}
          title={e.data.title}
          description={e.data.description}
          tags={e.data.tags}
          roles={e.data.roles}
          logoSrc={e.data.logoSrc}
          logoAlt={e.data.logoAlt ?? ""}
        />
      ))}
    </div>
  </section>
</BaseLayout>
